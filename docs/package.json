{
  "name": "morphoclip-docs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "bun --bun next build",
    "postbuild": "pagefind --site .next/server/app --output-path out/_pagefind",
    "start": "bun --bun next start -p 4000",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "deploy": "bun run scripts/deploy.ts"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "next": "^16.2.0",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.0",
    "dotenv": "^17.4.1",
    "pagefind": "^1.4.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.0"
  }
}
